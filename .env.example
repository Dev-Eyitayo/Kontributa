ENV=development
APP_BASE_URL=http://localhost:8000

# --- Database -----------------------------------------------------------
# Superuser connection -- used only for migrations and (in tests) schema
# bootstrap / role GRANT-REVOKE setup. Never what the running app queries as.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kontributa

# The restricted role the running application actually connects as --
# created automatically by the Phase 6 migration (83d4db43c592), with
# UPDATE/DELETE revoked on audit_log/contribution_events/payout_events.
# Keep APP_DB_ROLE/APP_DB_PASSWORD in sync with whatever the migration
# creates unless you've deliberately changed them.
RUNTIME_DATABASE_URL=postgresql+asyncpg://kontributa_app:kontributa_app_password@localhost:5432/kontributa
APP_DB_ROLE=kontributa_app
APP_DB_PASSWORD=kontributa_app_password

REDIS_URL=redis://localhost:6379/0

# --- Auth -----------------------------------------------------------------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# --- Monnify (payments) ----------------------------------------------------
# Sandbox vs live is a config change only -- never a code change.
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_INVOICE_EXPIRY_MINUTES=60
# Your Monnify disbursement wallet account number -- required by the Single
# Transfer API as sourceAccountNumber (the account payouts debit from).
# Find it under Wallets in the Monnify dashboard, or via the Wallet Balance
# API. Required before any real payout will succeed.
MONNIFY_SOURCE_ACCOUNT_NUMBER=

# --- Reconciliation job -----------------------------------------------------
RECONCILIATION_INTERVAL_MINUTES=20
RECONCILIATION_PENDING_THRESHOLD_MINUTES=60

# --- SendByte (email) -------------------------------------------------------
# Sandbox vs live is a config change only -- same pattern as Monnify above.
SENDBYTE_BASE_URL=https://api.sendbyte.africa
SENDBYTE_API_KEY=
SENDBYTE_FROM_EMAIL=noreply@kontributa.app
SENDBYTE_FROM_NAME=Kontributa

# --- Purse reminders (Phase 7) ----------------------------------------------
# Global kill switch -- set to false to stop reminder sends platform-wide
# without a code change.
REMINDERS_ENABLED=true
REMINDER_MIN_INTERVAL_DAYS=7

# --- Rate limiting -----------------------------------------------------------
# Fixed-window request caps on endpoints that can trigger a SendByte send,
# so a burst of traffic (or abuse) can't quietly exhaust the free tier.
RATE_LIMIT_REGISTER_PER_HOUR=10
RATE_LIMIT_FORGOT_PASSWORD_PER_HOUR=5
RATE_LIMIT_REMIND_PER_MINUTE=3
